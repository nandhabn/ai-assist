{
  "manifest_version": 3,
  "name": "AI Flow Recorder",
  "version": "1.0.0",
  "description": "Record user interaction flows for AI-powered test automation",
  "permissions": ["storage", "webRequest", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Flow Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "type": "module",
      "all_frames": false,
      "run_at": "document_end"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["chatgptBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
